# ── Application ──────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8010

# ── Postgres (Docker: host port 5442 = standard 5432 + 10) ───────────────────
DATABASE_URL=postgresql+psycopg://guardrail:guardrail@127.0.0.1:5442/guardrail

# ── Redis (Docker: host port 6389 = standard 6379 + 10) ──────────────────────
REDIS_URL=redis://127.0.0.1:6389/0

# ── DistilBERT maliciousness classifier ──────────────────────────────────────
# Path to a fine-tuned model directory produced by training/train_distilbert.py
# If the path does not exist, the heuristic fallback is used automatically.
MALICIOUSNESS_MODEL_PATH=artifacts/distilbert_guardrail
MALICIOUSNESS_THRESHOLD=0.6
USE_HEURISTIC_FALLBACK=true

# ── Guard thresholds ─────────────────────────────────────────────────────────
PII_BLOCK_THRESHOLD=0.8
PII_SANITIZE_THRESHOLD=0.3

# ── Downstream LLM (mocked locally; point at Ollama / OpenAI-compat API) ─────
# 11444 = Ollama default 11434 + 10
DOWNSTREAM_URL=http://127.0.0.1:11444/v1/chat/completions
# ── Auth ────────────────────────────────────────────────────────────────
# Comma-separated API keys. Leave empty string to disable authentication.
API_KEYS=

# ── Rate limiting ────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=1.0